{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*"]
  },
  "routes": [
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/.auth/login/aad", "allowedRoles": ["anonymous"] },
    { "route": "/.auth/login/google", "allowedRoles": ["anonymous"] }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:8.0"
  }
}
